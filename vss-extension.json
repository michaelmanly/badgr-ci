{
  "manifestVersion": 1,
  "id": "badgr-ci",
  "name": "Badgr Pipeline Check",
  "version": "1.0.6",
  "publisher": "aibadgr",
  "public": true,
  "description": "Badgr Pipeline Check — CI Failure Diagnosis for Azure DevOps. Always-on pipeline check that diagnoses failures, reports health, and scans for security issues. No API key required.",
  "categories": ["Azure Pipelines"],
  "tags": ["ci", "diagnosis", "pipeline", "devops", "badgr", "ai", "failure", "build-failure", "pipeline-failure", "azure-pipelines"],
  "targets": [{ "id": "Microsoft.VisualStudio.Services" }],
  "icons": { "default": "images/badgr-logo.png" },
  "content": {
    "details": { "path": "README.md" }
  },
  "links": {
    "getstarted": { "uri": "https://aibadgr.com" },
    "learn": { "uri": "https://github.com/michaelmanly/badgr-ci" },
    "support": { "uri": "mailto:hello@aibadgr.com" }
  },
  "repository": {
    "type": "git",
    "uri": "https://github.com/michaelmanly/badgr-ci"
  },
  "files": [
    { "path": "BadgrCI", "addressable": true },
    { "path": "dist/ci/azure/main.js", "addressable": true },
    { "path": "images/badgr-logo.png", "addressable": true }
  ],
  "contributions": [
    {
      "id": "BadgrCI",
      "type": "ms.vss-distributed-task.task",
      "targets": ["ms.vss-distributed-task.tasks"],
      "properties": { "name": "BadgrCI" }
    }
  ]
}
